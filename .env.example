# Primary database (PostgreSQL) — required at runtime
# Replace USER / PASSWORD; do not commit real credentials.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/documents_pg?schema=documents"

# --- Legacy MySQL (deprecated for Prisma; still used by lib/db.js mysql2 pool until Phase P1) ---
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# Local MySQL with no root password (common): leave empty
# Docker Compose in this repo (npm run db:up): use change-me
# MYSQL_PASSWORD=
# MYSQL_DATABASE=documents
# MYSQL_POOL_LIMIT=10

# SSL for managed MySQL (Aiven, RDS, Azure). Only relevant while mysql2 pool remains.
# MYSQL_SSL=auto
# Path to CA bundle when the provider issues one (enables stricter verification by default).
# MYSQL_SSL_CA=
# MYSQL_SSL_REJECT_UNAUTHORIZED=false

# Live site URL shape (default project slug: dispatch → /home, /about-us)
NEXT_PUBLIC_PUBLIC_PROJECT_SLUG=dispatch
# Set to your default project's slug for flat live URLs (e.g. `d` → `/home` not `/d/home`)
# Set to false to use /dispatch/home style URLs on the public site
NEXT_PUBLIC_FLAT_PUBLIC_URLS=true

# Dev server — bind 0.0.0.0 so other devices on same Wi‑Fi can open http://YOUR_LAN_IP:3000
# DEV_HOST=0.0.0.0

# Admin/builder host — /admin only works here (+ localhost in dev). Client sites use their own domains.
# Local placeholder OK for dev. Production: real subdomain, must match SITE_URL.
# BUILDER_APP_HOST=builder.yourdomain.com

# Admin authentication (required in production)
AUTH_SECRET=change-me-to-a-long-random-string-at-least-32-chars
# Force Secure cookie on HTTPS staging (recommended on server)
# AUTH_COOKIE_SECURE=true
# Public site URL for admin CSRF — production: https://same-host-as-BUILDER_APP_HOST
# SITE_URL=https://builder.yourdomain.com
# Local dev only — never enable in production
# AUTH_DISABLED=true
ADMIN_BOOTSTRAP_EMAIL=admin@localhost
ADMIN_BOOTSTRAP_PASSWORD=changeme
ADMIN_BOOTSTRAP_NAME=Super Admin

# Public form rate limits (per IP, per minute)
# FORM_SUBMIT_RATE_MAX=8
# FORM_ANALYTICS_RATE_MAX=40

# Public server IP shown in custom domain DNS instructions (A record @)
PLATFORM_SERVER_IP=YOUR_SERVER_IP

# Domain verification: production requires DNS TXT match by default.
# DOMAIN_VERIFY_MANUAL=true  — always allow manual verify (local/staging)
# DOMAIN_VERIFY_STRICT=true  — require DNS TXT even in development

# Media uploads: JPEG/PNG are auto-converted to WebP (smaller, faster). GIF stays as-is.
# MEDIA_KEEP_ORIGINAL=true  — store JPEG/PNG without WebP conversion

# Google Gemini — AI SEO Automation (server-side only; never commit keys)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_TIMEOUT_MS=25000
