{
  "name": "builder-custom",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true}); console.log('Cleared .next cache')\" && next dev",
    "build": "next build",
    "start": "next start",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "node --env-file=.env scripts/reset-db.mjs",
    "db:migrate": "node --env-file=.env scripts/migrate.mjs",
    "db:seed": "node --env-file=.env scripts/seed.mjs",
    "test": "node --test ./tests/builderHierarchy.test.mjs ./tests/builderTree.test.mjs ./tests/styleToCss.test.mjs ./tests/styleNormalizer.test.mjs ./tests/computeReorderFromDrop.test.mjs ./tests/publishedSnapshot.test.mjs ./tests/widgetRegistry.test.mjs ./tests/carouselWidget.test.mjs ./tests/actionExecutor.test.mjs ./tests/dataSourceRegistry.test.mjs ./tests/formValidation.test.mjs ./tests/runtimeConfigShape.test.mjs ./tests/projectPageRules.test.mjs ./tests/sanitizeRichHtml.test.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-virtual": "^3.13.24",
    "file-type": "^22.0.1",
    "isomorphic-dompurify": "^3.10.0",
    "mysql2": "^3.15.2",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5"
  }
}
