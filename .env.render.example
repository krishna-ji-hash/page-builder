# Render.com — page-builder service environment
# Copy each key into Render → Environment → Add Environment Variable
# Replace YOUR_* placeholders with values from Aiven console (Service → Connection info)
#
# Do NOT copy this file to .env for local dev — use .env.example (127.0.0.1) instead.
# Remote Aiven from a laptop often fails with ENOTFOUND / access denied when offline or creds rotate.

MYSQL_HOST=mysql-documents-live-krishnji69-36df.l.aivencloud.com
MYSQL_PORT=18350
MYSQL_USER=avnadmin
MYSQL_PASSWORD=YOUR_AIVEN_PASSWORD
MYSQL_DATABASE=defaultdb
MYSQL_SSL=auto
MYSQL_POOL_LIMIT=10

SITE_URL=https://page-builder-0ano.onrender.com
BUILDER_APP_HOST=page-builder-0ano.onrender.com

NEXT_PUBLIC_PUBLIC_PROJECT_SLUG=d
NEXT_PUBLIC_FLAT_PUBLIC_URLS=true

NODE_ENV=production
AUTH_SECRET=USE_openssl_rand_hex_32_MIN_32_CHARS

ADMIN_BOOTSTRAP_EMAIL=admin@localhost
ADMIN_BOOTSTRAP_PASSWORD=StrongP@ssw0rd-ChangeMe
ADMIN_BOOTSTRAP_NAME=Super Admin

NPM_CONFIG_PRODUCTION=false
