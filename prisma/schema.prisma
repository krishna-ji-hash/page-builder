  name          String    @db.VarChar(255)
  snapshot_json String
  created_at    DateTime  @db.Timestamptz(6)
  updated_at    DateTime? @db.Timestamptz(6)
  projects      Project   @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_reusable_blocks_project")

  @@index([project_id], map: "idx_17444_idx_reusable_blocks_project")
}

model seo_redirects {
  id               BigInt                      @id(map: "idx_17456_primary") @default(autoincrement())
  project_id       BigInt
  source_path      String                      @db.VarChar(512)
  destination_path String                      @db.VarChar(512)
  redirect_type    seo_redirects_redirect_type @default(dbgenerated("301"))
  active           Boolean                     @default(true)
  created_at       DateTime                    @db.Timestamptz(6)
  updated_at       DateTime?                   @db.Timestamptz(6)
  projects         Project                     @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_seo_redirect_project")

  @@unique([project_id, source_path], map: "idx_17456_uq_seo_redirect_project_source")
  @@index([project_id, active], map: "idx_17456_idx_seo_redirect_project_active")
}

