generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Admin users (`admin_users` table — existing auth).
model User {
  id                  BigInt                @id(map: "idx_17075_primary") @default(autoincrement())
  email               String                @unique(map: "idx_17075_uq_admin_users_email") @db.VarChar(50)
  passwordHash        String                @map("password_hash") @db.VarChar(50)
  displayName         String                @map("display_name") @db.VarChar(100)
  role                admin_users_role      @default(editor)
  isActive            Boolean               @default(true) @map("is_active")
  lastLoginAt         DateTime?             @map("last_login_at") @db.Timestamptz(6)
  createdAt           DateTime              @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime?             @updatedAt @map("updated_at") @db.Timestamptz(6)
  admin_activity_logs admin_activity_logs[]
  admin_sessions      admin_sessions[]
  admin_user_projects admin_user_projects[]
  pageVersions        PageVersion[]

  @@index([role], map: "idx_17075_idx_admin_users_role")
  @@map("admin_users")
}

model Project {
  id                  BigInt                 @id(map: "idx_17391_primary") @default(autoincrement())
  slug                String                 @unique(map: "idx_17391_uq_projects_slug") @db.VarChar(120)
  /// Primary custom domain (denormalized from `project_domains` when set).
  domain              String?                @unique(map: "idx_17391_uq_projects_domain") @db.VarChar(253)
  domainStatus        projects_domain_status @default(PENDING) @map("domain_status")
  lastVerifiedAt      DateTime?              @map("last_verified_at") @db.Timestamptz(6)
  homeSlug            String                 @default("home") @map("home_slug") @db.VarChar(180)
  status              projects_status        @default(ACTIVE)
  name                String                 @db.VarChar(255)
  title               String                 @db.VarChar(255)
  createdAt           DateTime               @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime?              @updatedAt @map("updated_at") @db.Timestamptz(6)
  type                projects_type          @default(website)
  configJson          String?                @map("config_json")
  admin_activity_logs admin_activity_logs[]
  admin_user_projects admin_user_projects[]
  form_analytics      form_analytics[]
  form_submissions    form_submissions[]
  global_components   global_components[]
  mediaAssets         MediaAsset[]
  menus               Menu[]
  pages               Page[]
  project_domains     project_domains[]
  reusable_blocks     reusable_blocks[]
  seo_redirects       seo_redirects[]
  siteSettings        SiteSetting[]

  @@map("projects")
}

model Page {
  id                                                      BigInt                @id(map: "idx_17341_primary") @default(autoincrement())
  projectId                                               BigInt                @map("project_id")
  slug                                                    String                @db.VarChar(180)
  status                                                  pages_status          @default(draft)
  /// Builder edits this JSON tree (synced from draft `builder_nodes`).
  draftJson                                               String?               @map("draft_json")
  /// Public/live routes render this JSON snapshot only.
  publishedJson                                           String?               @map("published_json")
  publishedAt                                             DateTime?             @map("published_at") @db.Timestamptz(6)
  title                                                   String                @db.VarChar(255)
  publishedVersionId                                      BigInt?               @map("published_version_id")
  createdAt                                               DateTime              @map("created_at") @db.Timestamptz(6)
  updatedAt                                               DateTime?             @updatedAt @map("updated_at") @db.Timestamptz(6)
  seoJson                                                 String?               @map("seo_json")
  seoTitle                                                String?               @map("seo_title") @db.VarChar(255)
  seoDescription                                          String?               @map("seo_description") @db.VarChar(512)
  seoKeywords                                             String?               @map("seo_keywords") @db.VarChar(512)
  ogImage                                                 String?               @map("og_image") @db.VarChar(2048)
  robotsIndex                                             Boolean               @default(true) @map("robots_index")
  robotsFollow                                            Boolean               @default(true) @map("robots_follow")
  canonicalUrl                                            String?               @map("canonical_url") @db.VarChar(2048)
  admin_activity_logs                                     admin_activity_logs[]
  builder_nodes                                           builder_nodes[]
  form_submissions                                        form_submissions[]
  menuItems                                               MenuItem[]
  versions                                                PageVersion[]
  page_versions_page_versions_page_idTopages              page_versions[]       @relation("page_versions_page_idTopages")
  project                                                 Project               @relation(fields: [projectId], references: [id], onUpdate: Restrict, map: "fk_pages_project")
  page_versions_pages_published_version_idTopage_versions page_versions?        @relation("pages_published_version_idTopage_versions", fields: [publishedVersionId], references: [id], onUpdate: Restrict, map: "fk_pages_published_version")

  @@unique([projectId, slug], map: "idx_17341_uq_pages_project_slug")
  @@index([publishedVersionId], map: "idx_17341_fk_pages_published_version")
  @@map("pages")
}

model Menu {
  id        BigInt         @id(map: "idx_17305_primary") @default(autoincrement())
  projectId BigInt         @map("project_id")
  name      String         @db.VarChar(120)
  location  menus_location
  createdAt DateTime       @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime?      @updatedAt @map("updated_at") @db.Timestamptz(6)
  items     MenuItem[]
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_menus_project")

  @@index([projectId, location], map: "idx_17305_idx_menus_project_location")
  @@map("menus")
}

model MenuItem {
  id        BigInt     @id(map: "idx_17317_primary") @default(autoincrement())
  menuId    BigInt     @map("menu_id")
  label     String     @db.VarChar(180)
  url       String     @default("") @db.VarChar(2048)
  pageId    BigInt?    @map("page_id")
  target    String     @default("_self") @db.VarChar(16)
  sortOrder BigInt     @default(0) @map("sort_order")
  parentId  BigInt?    @map("parent_id")
  menu      Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_menu_items_menu")
  page      Page?      @relation(fields: [pageId], references: [id], onUpdate: Restrict, map: "fk_menu_items_page")
  parent    MenuItem?  @relation("MenuItemHierarchy", fields: [parentId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_menu_items_parent")
  children  MenuItem[] @relation("MenuItemHierarchy")

  @@index([pageId], map: "idx_17317_fk_menu_items_page")
  @@index([menuId, sortOrder], map: "idx_17317_idx_menu_items_menu_sort")
  @@index([parentId], map: "idx_17317_idx_menu_items_parent")
  @@map("menu_items")
}

/// WordPress-style immutable revisions (`pages.draftJson` / publish snapshots).
/// Separate from legacy `page_versions` rows used by `builder_nodes`.
model PageVersion {
  id            BigInt                @id(map: "idx_17364_primary") @default(autoincrement())
  pageId        BigInt                @map("page_id")
  versionNumber BigInt                @map("version_number")
  snapshotJson  String                @map("snapshot_json")
  source        page_revisions_source
  createdAt     DateTime              @map("created_at") @db.Timestamptz(6)
  createdById   BigInt?               @map("created_by_id")
  createdBy     User?                 @relation(fields: [createdById], references: [id], onUpdate: Restrict, map: "fk_page_revisions_created_by")
  page          Page                  @relation(fields: [pageId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_page_revisions_page")

  @@unique([pageId, versionNumber], map: "idx_17364_uq_page_revisions_page_version")
  @@index([createdById], map: "idx_17364_fk_page_revisions_created_by")
  @@index([pageId, createdAt], map: "idx_17364_idx_page_revisions_page_created")
  @@map("page_revisions")
}

/// Project media library (`media_assets` — legacy table, Prisma-managed).
model MediaAsset {
  id           BigInt    @id(map: "idx_17283_primary") @default(autoincrement())
  projectId    BigInt    @map("project_id")
  folder       String?   @db.VarChar(255)
  kind         String    @db.VarChar(32)
  mimeType     String    @map("mime_type") @db.VarChar(191)
  originalName String    @map("original_name") @db.VarChar(255)
  fileName     String    @map("storage_name") @db.VarChar(255)
  storageKey   String    @map("storage_path") @db.VarChar(1024)
  url          String    @map("public_url") @db.VarChar(1024)
  thumbUrl     String?   @map("thumb_url") @db.VarChar(1024)
  width        BigInt?
  height       BigInt?
  size         Decimal   @default(0) @map("bytes") @db.Decimal
  title        String?   @db.VarChar(255)
  altText      String?   @map("alt_text") @db.VarChar(255)
  createdAt    DateTime  @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_media_assets_project")

  @@index([projectId, id], map: "idx_17283_idx_media_assets_project")
  @@index([projectId, createdAt], map: "idx_17283_idx_media_assets_project_created")
  @@index([projectId, folder], map: "idx_17283_idx_media_assets_project_folder")
  @@map("media_assets")
}

/// Singleton row (`id` = "main") — which project is active for flat dev URLs.
model SiteSetting {
  id              String   @id(map: "idx_17471_primary") @default("main") @db.VarChar(32)
  activeProjectId BigInt?  @map("active_project_id")
  activeProject   Project? @relation(fields: [activeProjectId], references: [id], onUpdate: Restrict, map: "fk_site_settings_active_project")

  @@index([activeProjectId], map: "idx_17471_idx_site_settings_active_project")
  @@map("site_settings")
}

model admin_activity_logs {
  id            BigInt   @id(map: "idx_17052_primary") @default(autoincrement())
  user_id       BigInt?
  project_id    BigInt?
  page_id       BigInt?
  action        String   @db.VarChar(64)
  metadata_json String?
  created_at    DateTime @db.Timestamptz(6)
  pages         Page?    @relation(fields: [page_id], references: [id], onUpdate: Restrict, map: "fk_admin_activity_page")
  projects      Project? @relation(fields: [project_id], references: [id], onUpdate: Restrict, map: "fk_admin_activity_project")
  admin_users   User?    @relation(fields: [user_id], references: [id], onUpdate: Restrict, map: "fk_admin_activity_user")

  @@index([page_id], map: "idx_17052_fk_admin_activity_page")
  @@index([action, created_at], map: "idx_17052_idx_admin_activity_action")
  @@index([created_at], map: "idx_17052_idx_admin_activity_created")
  @@index([project_id, created_at], map: "idx_17052_idx_admin_activity_project")
  @@index([user_id, created_at], map: "idx_17052_idx_admin_activity_user")
}

model admin_sessions {
  id          BigInt    @id(map: "idx_17062_primary") @default(autoincrement())
  user_id     BigInt
  token_hash  String    @unique(map: "idx_17062_uq_admin_sessions_token") @db.Char(64)
  expires_at  DateTime? @db.Timestamptz(6)
  ip_address  String?   @db.VarChar(45)
  user_agent  String?   @db.VarChar(512)
  created_at  DateTime  @db.Timestamptz(6)
  admin_users User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_admin_sessions_user")

  @@index([expires_at], map: "idx_17062_idx_admin_sessions_expires")
  @@index([user_id], map: "idx_17062_idx_admin_sessions_user")
}

model admin_user_projects {
  id          BigInt   @id(map: "idx_17089_primary") @default(autoincrement())
  user_id     BigInt
  project_id  BigInt
  created_at  DateTime @db.Timestamptz(6)
  projects    Project  @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_admin_user_projects_project")
  admin_users User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_admin_user_projects_user")

  @@unique([user_id, project_id], map: "idx_17089_uq_admin_user_projects")
  @@index([project_id], map: "idx_17089_idx_admin_user_projects_project")
}

model blog_authors {
  id          BigInt    @id(map: "idx_17100_primary") @default(autoincrement())
  project_id  BigInt
  name        String    @db.VarChar(160)
  designation String?   @db.VarChar(160)
  bio         String?
  avatar      String?   @db.VarChar(500)
  created_at  DateTime  @db.Timestamptz(6)
  updated_at  DateTime? @db.Timestamptz(6)

  @@index([project_id], map: "idx_17100_idx_blog_authors_project")
}

model blog_categories {
  id          BigInt    @id(map: "idx_17113_primary") @default(autoincrement())
  project_id  BigInt
  name        String    @db.VarChar(160)
  slug        String    @db.VarChar(180)
  description String?
  created_at  DateTime  @db.Timestamptz(6)
  updated_at  DateTime? @db.Timestamptz(6)

  @@unique([project_id, slug], map: "idx_17113_uniq_blog_category_project_slug")
  @@index([project_id], map: "idx_17113_idx_blog_categories_project")
}

model blog_post_tags {
  post_id BigInt
  tag_id  BigInt

  @@id([post_id, tag_id], map: "idx_17161_primary")
  @@index([tag_id], map: "idx_17161_idx_blog_post_tags_tag")
}

model blog_posts {
  id                     BigInt    @id(map: "idx_17125_primary") @default(autoincrement())
  project_id             BigInt
  title                  String    @db.VarChar(240)
  slug                   String    @db.VarChar(180)
  excerpt                String?
  featured_image         String?   @db.VarChar(500)
  featured_image_alt     String?   @db.VarChar(240)
  featured_image_caption String?   @db.VarChar(500)
  category_id            BigInt?
  author_id              BigInt?
  content_json           String?
  content_html           String?
  faqs_json              String?
  key_takeaways_json     String?
  toc_items_json         String?
  internal_links_json    String?
  external_links_json    String?
  status                 String    @default("draft") @db.VarChar(24)
  published_at           DateTime? @db.Timestamptz(6)
  scheduled_at           DateTime? @db.Timestamptz(6)
  read_time              String?   @db.VarChar(40)
  seo_title              String?   @db.VarChar(240)
  seo_description        String?
  focus_keywords         String?   @db.VarChar(500)
  meta_keywords          String?   @db.VarChar(320)
  canonical_url          String?   @db.VarChar(500)
  og_image               String?   @db.VarChar(500)
  og_title               String?   @db.VarChar(240)
  og_description         String?
  social_image           String?   @db.VarChar(500)
  robots                 String    @default("index") @db.VarChar(40)
  visibility             String    @default("public") @db.VarChar(24)
  schema_type            String    @default("article") @db.VarChar(40)
  schema_json_ld         String?
  enable_article_schema  Boolean   @default(true)
  enable_faq_schema      Boolean   @default(false)
  preview_checked        Boolean   @default(false)
  created_at             DateTime  @db.Timestamptz(6)
  updated_at             DateTime? @db.Timestamptz(6)
  deleted_at             DateTime? @db.Timestamptz(6)

  @@unique([project_id, slug], map: "idx_17125_uniq_blog_post_project_slug")
  @@index([author_id], map: "idx_17125_idx_blog_posts_author")
  @@index([category_id], map: "idx_17125_idx_blog_posts_category")
  @@index([deleted_at], map: "idx_17125_idx_blog_posts_deleted")
  @@index([project_id], map: "idx_17125_idx_blog_posts_project")
  @@index([published_at], map: "idx_17125_idx_blog_posts_published_at")
  @@index([status], map: "idx_17125_idx_blog_posts_status")
}

model blog_settings {
  project_id    BigInt    @id(map: "idx_17166_primary")
  settings_json String?
  updated_at    DateTime? @db.Timestamptz(6)
}

model blog_tags {
  id         BigInt    @id(map: "idx_17173_primary") @default(autoincrement())
  project_id BigInt
  name       String    @db.VarChar(120)
  slug       String    @db.VarChar(160)
  created_at DateTime  @db.Timestamptz(6)
  updated_at DateTime? @db.Timestamptz(6)

  @@unique([project_id, slug], map: "idx_17173_uniq_blog_tag_project_slug")
  @@index([project_id], map: "idx_17173_idx_blog_tags_project")
}

model builder_nodes {
  id                  BigInt          @id(map: "idx_17183_primary") @default(autoincrement())
  page_id             BigInt
  version_id          BigInt
  parent_node_id      BigInt?
  node_type           String          @db.VarChar(64)
  display_name        String          @db.VarChar(255)
  props_json          String
  position_index      BigInt          @default(0)
  created_at          DateTime        @db.Timestamptz(6)
  updated_at          DateTime?       @db.Timestamptz(6)
  data_json           String?
  actions_json        String?
  pages               Page            @relation(fields: [page_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_builder_nodes_page")
  builder_nodes       builder_nodes?  @relation("builder_nodesTobuilder_nodes", fields: [parent_node_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_builder_nodes_parent")
  other_builder_nodes builder_nodes[] @relation("builder_nodesTobuilder_nodes")
  page_versions       page_versions   @relation(fields: [version_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_builder_nodes_version")

  @@index([page_id], map: "idx_17183_fk_builder_nodes_page")
  @@index([parent_node_id], map: "idx_17183_idx_builder_nodes_parent")
  @@index([version_id, position_index], map: "idx_17183_idx_builder_nodes_version")
}

model cms_collections {
  id          BigInt    @id(map: "idx_17199_primary") @default(autoincrement())
  project_id  BigInt
  name        String    @db.VarChar(120)
  slug        String    @db.VarChar(120)
  type        String    @default("custom") @db.VarChar(64)
  schema_json String?
  created_at  DateTime  @db.Timestamptz(6)
  updated_at  DateTime? @db.Timestamptz(6)

  @@unique([project_id, slug], map: "idx_17199_uniq_project_collection_slug")
  @@index([project_id], map: "idx_17199_idx_cms_collections_project")
}

model cms_items {
  id            BigInt    @id(map: "idx_17213_primary") @default(autoincrement())
  collection_id BigInt
  status        String    @default("draft") @db.VarChar(24)
  slug          String    @db.VarChar(180)
  title         String?   @db.VarChar(220)
  data_json     String?
  created_at    DateTime  @db.Timestamptz(6)
  updated_at    DateTime? @db.Timestamptz(6)
  published_at  DateTime? @db.Timestamptz(6)
  seo_json      String?

  @@unique([collection_id, slug], map: "idx_17213_uniq_collection_item_slug")
  @@index([collection_id], map: "idx_17213_idx_cms_items_collection")
  @@index([published_at], map: "idx_17213_idx_cms_items_published_at")
  @@index([status], map: "idx_17213_idx_cms_items_status")
}

model form_analytics {
  id           BigInt                    @id(map: "idx_17227_primary") @default(autoincrement())
  project_id   BigInt
  page_id      Decimal?                  @db.Decimal
  form_node_id String                    @db.VarChar(96)
  event_type   form_analytics_event_type
  created_at   DateTime                  @db.Timestamptz(6)
  projects     Project                   @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_form_analytics_project")

  @@index([event_type], map: "idx_17227_idx_form_analytics_event")
  @@index([form_node_id], map: "idx_17227_idx_form_analytics_form")
  @@index([project_id], map: "idx_17227_idx_form_analytics_project")
}

model form_submissions {
  id              BigInt   @id(map: "idx_17239_primary") @default(autoincrement())
  project_id      BigInt
  page_id         BigInt
  form_node_id    String   @db.VarChar(96)
  submission_json String
  meta_json       String?
  status          String   @default("received") @db.VarChar(32)
  created_at      DateTime @db.Timestamptz(6)
  pages           Page     @relation(fields: [page_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_form_submissions_page")
  projects        Project  @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_form_submissions_project")

  @@index([form_node_id], map: "idx_17239_idx_form_submissions_form")
  @@index([page_id], map: "idx_17239_idx_form_submissions_page")
  @@index([project_id], map: "idx_17239_idx_form_submissions_project")
  @@index([status], map: "idx_17239_idx_form_submissions_status")
}

model global_component_revisions {
  id                BigInt            @id(map: "idx_17271_primary") @default(autoincrement())
  component_id      BigInt
  revision          BigInt
  snapshot_json     String
  created_at        DateTime          @db.Timestamptz(6)
  global_components global_components @relation(fields: [component_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_component_revs_component")

  @@unique([component_id, revision], map: "idx_17271_uniq_component_revision")
  @@index([component_id, revision], map: "idx_17271_idx_component_rev_component")
}

model global_components {
  id                         BigInt                       @id(map: "idx_17254_primary") @default(autoincrement())
  project_id                 BigInt
  type                       String                       @db.VarChar(64)
  name                       String                       @db.VarChar(255)
  current_revision           BigInt                       @default(1)
  snapshot_json              String
  linked_pages_count         BigInt                       @default(0)
  created_at                 DateTime                     @db.Timestamptz(6)
  updated_at                 DateTime?                    @db.Timestamptz(6)
  global_component_revisions global_component_revisions[]
  projects                   Project                      @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_global_components_project")

  @@index([project_id, id], map: "idx_17254_idx_global_components_project")
}

model migrations {
  id         BigInt   @id(map: "idx_17333_primary") @default(autoincrement())
  name       String   @unique(map: "idx_17333_uq_migrations_name") @db.VarChar(255)
  applied_at DateTime @db.Timestamptz(6)
}

model page_versions {
  id                                              BigInt               @id(map: "idx_17377_primary") @default(autoincrement())
  page_id                                         BigInt
  version_number                                  BigInt
  status                                          page_versions_status @default(draft)
  snapshot_json                                   String
  created_at                                      DateTime             @db.Timestamptz(6)
  builder_nodes                                   builder_nodes[]
  pages_page_versions_page_idTopages              Page                 @relation("page_versions_page_idTopages", fields: [page_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_page_versions_page")
  pages_pages_published_version_idTopage_versions Page[]               @relation("pages_published_version_idTopage_versions")

  @@unique([page_id, version_number], map: "idx_17377_uq_page_versions_page_version")
  @@index([page_id, status], map: "idx_17377_idx_page_versions_page_status")
}

model project_apps {
  id            BigInt    @id(map: "idx_17412_primary") @default(autoincrement())
  project_id    BigInt
  app_id        String    @db.VarChar(64)
  enabled       Boolean   @default(false)
  settings_json String?
  created_at    DateTime  @db.Timestamptz(6)
  updated_at    DateTime? @db.Timestamptz(6)

  @@unique([project_id, app_id], map: "idx_17412_uniq_project_app")
  @@index([enabled], map: "idx_17412_idx_project_apps_enabled")
  @@index([project_id], map: "idx_17412_idx_project_apps_project")
}

model project_domains {
  id                 BigInt    @id(map: "idx_17425_primary") @default(autoincrement())
  project_id         BigInt
  domain             String    @unique(map: "idx_17425_uq_project_domains_domain") @db.VarChar(253)
  verified           Boolean   @default(false)
  ssl_status         String    @default("pending") @db.VarChar(32)
  verification_token String    @db.VarChar(64)
  is_primary         Boolean   @default(false)
  created_at         DateTime  @db.Timestamptz(6)
  updated_at         DateTime? @db.Timestamptz(6)
  last_checked_at    DateTime? @db.Timestamptz(6)
  verification_error String?   @db.VarChar(512)
  projects           Project   @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_project_domains_project")

  @@index([project_id], map: "idx_17425_idx_project_domains_project")
}

model reusable_blocks {
