# Copy to `.env.production` on your server and fill in real values.
# Pre-flight: node --env-file=.env.production scripts/verify-production-deploy.mjs --build

NODE_ENV=production
PORT=3000

# MySQL (production database — not localhost root)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=builder_app
MYSQL_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
MYSQL_DATABASE=builder_production
DATABASE_URL="mysql://builder_app:CHANGE_ME_STRONG_DB_PASSWORD@127.0.0.1:3306/builder_production"

# Admin / builder console — ONLY this host serves /admin (client domains are public sites only)
BUILDER_APP_HOST=builder.yourdomain.com
SITE_URL=https://builder.yourdomain.com

# Required — 32+ random characters (openssl rand -hex 32)
AUTH_SECRET=CHANGE_ME_USE_openssl_rand_hex_32

# Strong bootstrap password (first deploy only), then change in admin
ADMIN_BOOTSTRAP_EMAIL=admin@yourdomain.com
ADMIN_BOOTSTRAP_PASSWORD=CHANGE_ME_STRONG_PASSWORD
ADMIN_BOOTSTRAP_NAME=Super Admin

# Public server IP — shown in Admin → Domains DNS instructions (A record)
PLATFORM_SERVER_IP=203.0.113.10

# HTTPS cookies (recommended behind TLS terminator)
AUTH_COOKIE_SECURE=true

# Never on production:
# AUTH_DISABLED=true

# Optional: manual domain verify on staging (skip DNS TXT)
# DOMAIN_VERIFY_MANUAL=true
